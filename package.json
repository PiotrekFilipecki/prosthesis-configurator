{
  "name": "glaze_creator",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "file-saver": "^2.0.2",
    "gsap": "^3.14.2",
    "html2canvas": "^1.0.0-alpha.12",
    "jspdf": "^1.3.5",
    "npm-run-all": "^4.1.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.9",
    "react-router-dom": "^4.2.2",
    "react-step-progress-bar": "^1.0.3",
